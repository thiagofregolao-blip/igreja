# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/catedral_bingo

# ===== JWT =====
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_REFRESH_SECRET=change-me-in-production-use-different-strong-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== Admin Seed =====
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@catedralkatuete.com.py
ADMIN_CEDULA=0000000
ADMIN_PHONE=+595981000000
ADMIN_PASSWORD=ChangeMe123!

# ===== Email (Resend) =====
# EMAIL_FROM deve usar um domínio VERIFICADO no Resend (catedralkatuete.com.py).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Catedral Sagrado Corazón <no-reply@catedralkatuete.com.py>

# ===== WhatsApp (Z-API or Evolution API) =====
WHATSAPP_PROVIDER=zapi
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# OR Evolution:
EVOLUTION_BASE_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=

# ===== Bancard (preparação futura) =====
BANCARD_API_KEY=
BANCARD_PRIVATE_KEY=
BANCARD_PUBLIC_KEY=
BANCARD_WEBHOOK_SECRET=

# ===== Dinelco — Embedded Checkout da Bepsa (cartão online) =====
# DINELCO_SKEY: API key secreta do comércio (portal Bepsa). Enquanto vazio,
# o pagamento com cartão aparece como "Em configuração" (desativado).
# DINELCO_BASE_URL: dev/sandbox por padrão; troque pelo host de produção quando liberado.
DINELCO_SKEY=
DINELCO_BASE_URL=https://dev-sgwf-01.bepsa.com.py

# ===== Uploads =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# ===== URLs =====
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
API_URL=http://localhost:3000

# ===== Server =====
PORT=3000
NODE_ENV=development
RESERVATION_TTL_MINUTES=15
