{
  "name": "catedral-bingo",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de venda online de cupons de bingo para a Catedral Sagrado Corazón de Katueté",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n API,WEB,ADMIN -c yellow,cyan,magenta \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:admin\"",
    "dev:api": "npm run dev --workspace=@catedral/api",
    "dev:web": "npm run dev --workspace=@catedral/web",
    "dev:admin": "npm run dev --workspace=@catedral/admin",
    "build:api": "npm run build --workspace=@catedral/api",
    "build:web": "npm run build --workspace=@catedral/web",
    "build:admin": "npm run build --workspace=@catedral/admin",
    "build": "npm run build:web && npm run build:admin && npm run build:api",
    "start": "npm run start --workspace=@catedral/api",
    "start:api": "npm run start --workspace=@catedral/api",
    "prisma:generate": "npm run prisma:generate --workspace=@catedral/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=@catedral/api",
    "prisma:deploy": "npm run prisma:deploy --workspace=@catedral/api",
    "prisma:seed": "npm run prisma:seed --workspace=@catedral/api",
    "setup": "npm install && npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
